{
  "name": "money-manager",
  "version": "1.10.0",
  "author": "David Hulme <dhulme@outlook.com>",
  "description": "A desktop application for managing your personal finances and accounts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhulme/money-manager.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:dist": "electron-vite build && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "productName": "Money Manager",
    "appId": "uk.co.dhulme.money-manager",
    "directories": {
      "output": "build"
    },
    "files": [
      "out/**/*"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "icon": "logo.png"
    },
    "win": {
      "icon": "logo.png"
    },
    "linux": {
      "icon": "logo.png"
    }
  },
  "dependencies": {
    "big.js": "^6.2.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^2.29.1",
    "fs-extra": "^10.1.0",
    "papaparse": "^5.3.2",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.0",
    "vuetify": "^3.8.1",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@mdi/font": "^7.4.47",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/eslint-plugin": "^1.6.15",
    "@vue/test-utils": "^2.4.6",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.8.1",
    "sass": "^1.86.3",
    "vite-plugin-vuetify": "^2.1.1",
    "vitest": "^4.1.3"
  }
}
